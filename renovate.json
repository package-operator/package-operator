{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "tekton": {
    "fileMatch": [
      "^\\.tekton/.*\\.ya?ml$"
    ]
  },
  "packageRules": [
    {
      "groupName": "konflux",
      "matchPackageNames": [
        "quay.io/konflux-ci/tekton-catalog/*"
      ],
      "automerge": true
    }
  ]
}
